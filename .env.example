# LLM Provider: "gemini" (default, free) or "openai"
LLM_PROVIDER=gemini

# Required when LLM_PROVIDER=gemini — get free key at https://aistudio.google.com
GEMINI_API_KEY=

# Required when LLM_PROVIDER=openai
OPENAI_API_KEY=

# Server configuration (optional — defaults shown)
# HOST=0.0.0.0
# PORT=8000
