# LLM Provider: "gemini" (default, free), "openai", or "groq"
LLM_PROVIDER=gemini

# Required when LLM_PROVIDER=gemini — get free key at https://aistudio.google.com
GEMINI_API_KEY=

# Required when LLM_PROVIDER=openai
# NOTE: Also required for voice transcription (POST /transcribe) regardless of LLM_PROVIDER.
# If LLM_PROVIDER=groq but OPENAI_API_KEY is absent, chat works but /transcribe returns 503.
OPENAI_API_KEY=

# Required when LLM_PROVIDER=groq — get key at https://console.groq.com
# LLM_PROVIDER=groq
# GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional bearer token required for admin review APIs and `/chat` debug mode
ADMIN_API_TOKEN=
# Voice transcription backend (used by POST /transcribe)
# VOICE_TRANSCRIPTION_ENABLED=true
# VOICE_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
# VOICE_TRANSCRIPTION_MAX_BYTES=5000000

# Comma-separated frontend origins allowed to call the API.
# Add your hosted frontend origin when deploying.
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# Data/artifact paths (optional — defaults shown)
# RAW_CORPUS_DIR=dataset/itc2026_ai_corpus
# DATA_DIR=data
# AUTO_BUILD_ARTIFACTS=true
# CONVERSATION_DB_PATH=data/conversations.db
# CONVERSATION_HISTORY_MAX_TURNS=10

# Grounding thresholds
# GROUNDING_MIN_TOP_SCORE=0.3
# GROUNDING_MIN_RESULTS=1
# GROUNDING_SCORE_AGGREGATION=max
# GROUNDING_EXPECTED_TOP_K=5

# Hosted frontend build only (docker-compose.hosted.yml now proxies API via frontend origin):
# PUBLIC_API_BASE_URL is optional/legacy and not required for hosted compose.

# Server configuration (optional — defaults shown)
# LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8000
