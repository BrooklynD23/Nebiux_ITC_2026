# Set to "true" only when you want to run the frontend without the backend.
VITE_USE_MOCK=false

# Base URL for the backend API when the frontend is not using the Vite dev proxy.
# Leave empty for local dev — the Vite proxy forwards /chat to the backend.
# Set to the full origin for hosted/static deployments, e.g.:
#   VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=

# Where the Vite dev server should proxy /chat during local development.
VITE_DEV_PROXY_TARGET=http://localhost:8000
