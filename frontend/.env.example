# Set to "false" to use the live API instead of mock data
VITE_USE_MOCK=true

# Base URL for the backend API (only used when VITE_USE_MOCK=false).
# Leave empty for local dev — the Vite proxy forwards /chat → http://localhost:8000.
# Set to the full origin for production / vite preview, e.g.:
#   VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=
